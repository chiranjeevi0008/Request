<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>A Special Question ❤️</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    background:linear-gradient(135deg,#ff9a9e,#fad0c4);
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
    overflow:hidden;
}

.card{
    background:white;
    padding:40px;
    border-radius:20px;
    text-align:center;
    width:90%;
    max-width:500px;
    box-shadow:0 15px 35px rgba(0,0,0,.2);
}

h1{
    color:#ff4081;
    margin-bottom:20px;
}

p{
    font-size:20px;
    margin-bottom:30px;
}

button{
    padding:15px 35px;
    font-size:18px;
    border:none;
    border-radius:40px;
    cursor:pointer;
    transition:.3s;
}

#yes{
    background:#ff4081;
    color:white;
    margin-right:20px;
}

#yes:hover{
    transform:scale(1.1);
}

#no{
    background:#666;
    color:white;
    position:absolute;
}

#result{
    font-size:28px;
    color:#ff4081;
    margin-top:20px;
}
</style>
</head>

<body>

<div class="card">
    <h1>❤️ Hey Beautiful ❤️</h1>

    <p id="question">
        Will you go on a date with me? 🥺
    </p>

    <button id="yes">YES ❤️</button>
    <button id="no">NO 😅</button>

    <div id="result"></div>
</div>

<script>

const noBtn=document.getElementById("no");
const yesBtn=document.getElementById("yes");
const question=document.getElementById("question");
const result=document.getElementById("result");

let count=0;

function moveButton(){

    if(count<8){

        const x=Math.random()*(window.innerWidth-150);
        const y=Math.random()*(window.innerHeight-80);

        noBtn.style.left=x+"px";
        noBtn.style.top=y+"px";

        count++;

    }else{

        question.innerHTML="🥺 Why not? He's actually a really good boy... give him one chance? ❤️";

        noBtn.innerHTML="Still No 😅";
        noBtn.style.position="static";
    }
}

noBtn.addEventListener("mouseover",moveButton);

noBtn.addEventListener("click",moveButton);

yesBtn.onclick=function(){

document.body.innerHTML=`
<div style="
display:flex;
justify-content:center;
align-items:center;
height:100vh;
background:linear-gradient(135deg,#ff9a9e,#fad0c4);
font-family:Poppins,sans-serif;
text-align:center;
padding:20px;
">
<div>
<h1 style="font-size:60px;color:white;">YAYYY!! ❤️🥳</h1>
<h2 style="color:white;margin-top:20px;">
You've just made someone the happiest person alive! 💕
</h2>
<p style="font-size:28px;color:white;margin-top:20px;">
Can't wait for our date! 🌹✨
</p>
<div style="font-size:80px;margin-top:30px;">
🥰💖🌹✨
</div>
</div>
</div>
`;

}

</script>

</body>
</html>
